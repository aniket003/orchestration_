# Azure OpenAI resource endpoint, not the full chat-completions URL.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-api-key

# This is the Azure deployment name assigned to your GPT-5 deployment.
AZURE_OPENAI_DEPLOYMENT=gpt-5
AZURE_OPENAI_MODEL=gpt-5

# Structured output is supported on Azure API versions from 2024-08-01-preview.
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MAX_COMPLETION_TOKENS=3000
AZURE_OPENAI_REASONING_EFFORT=low
AZURE_OPENAI_TIMEOUT_SECONDS=240
AZURE_OPENAI_MAX_RETRIES=2
